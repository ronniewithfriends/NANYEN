{
  "expo": {
    "name": "NANYEN",
    "slug": "nanyen",
    "version": "0.1.0",
    "scheme": "nanyen",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.nanyen.mobile",
      "appleTeamId": "94ZX7L3A2K",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.app.nanyen.mobile"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "5"
    },
    "android": {
      "package": "app.nanyen.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ff7ac6"
      },
      "versionCode": 2
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#fff0fb"
        }
      ],
      "@bacons/apple-targets"
    ],
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "app.nanyen.mobile.widget",
                  "targetName": "NANYENWidget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.app.nanyen.mobile"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "dca6e341-a14b-48a6-b589-0c221ab0fc82"
      }
    },
    "owner": "ronniewithfriends"
  }
}
